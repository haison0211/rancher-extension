export function importTypes($extension) { 
  $extension.register('detail', 'node', () => import(/* webpackChunkName: "detail" */'@pkg/detail/node.vue'));
  $extension.register('list', 'node', () => import(/* webpackChunkName: "list" */'@pkg/list/node.vue'));
  $extension.register('list', 'pod', () => import(/* webpackChunkName: "list" */'@pkg/list/pod.vue'));
  $extension.register('list', 'service', () => import(/* webpackChunkName: "list" */'@pkg/list/service.vue'));
  $extension.register('models', 'cluster/node', () => require(/* webpackChunkName: "models" */'@pkg/models/cluster/node.js'));
  $extension.register('models', 'pod', () => require(/* webpackChunkName: "models" */'@pkg/models/pod.js'));
  $extension.register('models', 'service', () => require(/* webpackChunkName: "models" */'@pkg/models/service.js'));
  $extension.register('l10n', 'en-us', () => import('@pkg/l10n/en-us.yaml'));
};
